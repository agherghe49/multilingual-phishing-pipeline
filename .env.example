# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# ── Generator & Evaluator API keys ────────────────────────────────────────
# Required if using DeepSeek as generator or evaluator backend
DEEPSEEK_API_KEY=sk-...

# Required if using Kimi K2 as generator
KIMI_API_KEY=...

# Required if using Together AI (Qwen2.5-72B, Llama-3.3-70B)
TOGETHER_API_KEY=...

# ── HuggingFace ────────────────────────────────────────────────────────────
# Required for downloading gated models (e.g. Qwen2.5-7B-Instruct)
HF_TOKEN=hf_...

# ── Local vLLM (optional) ──────────────────────────────────────────────────
# If serving a model locally via vLLM, set a dummy key or leave empty
VLLM_API_KEY=token-placeholder
